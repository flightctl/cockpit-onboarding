{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "allowImportingTsExtensions": true,
    "exactOptionalPropertyTypes": true,
    "jsx": "react",
    "lib": [
      "dom",
      "es2020"
    ],
    "paths": {
        "*": ["./pkg/lib/*"]
    },
    "moduleResolution": "bundler",
    "noEmit": true,
    "strict": true,
    "target": "es2020"
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    "test/**/*.ts",
    "test/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "**/*.js",
    "**/*.jsx"
  ]
}
