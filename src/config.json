{
  "version": "1.0",
  "runOnce": true,
  "keepCockpit": false,
  "hideModules": true,
  "autoReboot": false,
  "network": {
    "wifiAp": {
      "enabled": true,
      "ssidPrefix": "cockpit-",
      "interface": "",
      "password": ""
    },
    "ethernet": {
      "enabled": false,
      "staticIp": "192.168.100.1"
    }
  },
  "enrollmentServices": [
    {
      "id": "flightctl",
      "name": "Flight Control",
      "description": "Enroll this device into Flight Control fleet management",
      "endpoint": {
        "url": "",
        "allowUserOverride": true
      },
      "credentialsSchema": {
        "type": "object",
        "oneOf": [
          {
            "title": "Token",
            "properties": {
              "token": { "type": "string", "title": "Token", "format": "password" }
            },
            "required": ["token"]
          },
          {
            "title": "Username & password",
            "properties": {
              "username": { "type": "string", "title": "Username" },
              "password": { "type": "string", "title": "Password", "format": "password" }
            },
            "required": ["username", "password"]
          }
        ]
      },
      "scriptPath": "/usr/share/cockpit/system-onboarding/system-onboarding.d/flightctl-enroll.sh"
    }
  ],
  "connectivityTest": {
    "host": "www.google.com"
  },
  "led": {
    "enabled": false,
    "states": {
      "ready": "ready",
      "in-progress": "in-progress",
      "applying": "applying",
      "success": "success",
      "error": "error",
      "off": "off"
    }
  }
}
