{
  "version": "1.0",
  "runOnce": true,
  "keepCockpit": false,
  "hideModules": true,
  "autoReboot": false,
  "network": {
    "wifiAp": {
      "enabled": true,
      "ssidPrefix": "cockpit-",
      "interface": "",
      "password": ""
    },
    "ethernet": {
      "enabled": false,
      "staticIp": "192.168.100.1"
    }
  },
  "flightctl": {
    "defaultEndpoint": ""
  },
  "connectivityTest": {
    "host": "www.google.com"
  },
  "led": {
    "enabled": false,
    "states": {
      "ready": "ready",
      "in-progress": "in-progress",
      "applying": "applying",
      "success": "success",
      "error": "error",
      "off": "off"
    }
  }
}
