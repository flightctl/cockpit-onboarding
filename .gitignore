!/pkg/lib/
/pkg/lib/*
!/pkg/lib/cockpit/
/pkg/lib/cockpit/*
!/pkg/lib/cockpit/networkmanager/
/pkg/lib/cockpit/networkmanager/*
!/pkg/lib/cockpit/networkmanager/interfaces.d.ts
/node_modules/
/tmp/
/tools/
 
# subdirs (/subdir/...)
/packaging/arch/PKGBUILD
/packaging/debian/changelog
/po/*.pot
 /po/LINGUAS
/test/common/
/test/images/
/test/static-code

