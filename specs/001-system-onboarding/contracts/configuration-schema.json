{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cockpit-project.org/schemas/system-onboarding-config-v1.json",
  "title": "Cockpit System Onboarding Configuration",
  "description": "Configuration file schema for the Cockpit System Onboarding plugin",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0",
      "description": "Configuration schema version (must be '1.0')"
    },
    "runOnce": {
      "type": "boolean",
      "default": true,
      "description": "Disable the plugin and remove onboarding user after successful completion"
    },
    "keepCockpit": {
      "type": "boolean",
      "default": false,
      "description": "Keep Cockpit web console enabled after onboarding completion"
    },
    "hideModules": {
      "type": "boolean",
      "default": true,
      "description": "Hide other Cockpit modules during onboarding (show only System Onboarding)"
    },
    "autoReboot": {
      "type": "boolean",
      "default": false,
      "description": "Automatically reboot the system after applying configuration changes"
    },
    "network": {
      "type": "object",
      "description": "Network interface configuration for initial system access",
      "properties": {
        "wifiAp": {
          "type": "object",
          "description": "WiFi access point configuration for initial wireless access",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": false,
              "description": "Enable temporary WiFi access point on first boot"
            },
            "ssidPrefix": {
              "type": "string",
              "default": "setup-",
              "minLength": 1,
              "maxLength": 20,
              "pattern": "^[a-zA-Z0-9_-]+$",
              "description": "SSID prefix (full SSID will be <prefix><hostname>-<random>)"
            },
            "interface": {
              "type": "string",
              "description": "WiFi interface name (e.g., 'wlan0'). If not specified, first available WiFi interface will be used."
            },
            "password": {
              "type": "string",
              "minLength": 8,
              "maxLength": 63,
              "default": "onboarding",
              "description": "WPA passphrase for the access point (8-63 characters)"
            }
          }
        },
        "ethernet": {
          "type": "object",
          "description": "Ethernet interface configuration for wired access",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true,
              "description": "Configure Ethernet interface with well-known static IP on first boot"
            },
            "interface": {
              "type": "string",
              "description": "Ethernet interface name (e.g., 'eth0', 'eno1'). If not specified, first available Ethernet interface will be used."
            },
            "staticIp": {
              "type": "string",
              "format": "ipv4",
              "default": "192.168.100.1",
              "description": "Well-known static IPv4 address for initial access"
            }
          }
        }
      }
    },
    "enrollmentServices": {
      "type": "array",
      "description": "List of management services available for device enrollment",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$",
            "description": "Unique service identifier (lowercase alphanumeric and hyphens only)"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "description": "Display name for the service"
          },
          "description": {
            "type": "string",
            "maxLength": 500,
            "description": "User-facing description of the service"
          },
          "endpoint": {
            "type": "object",
            "description": "Service endpoint configuration",
            "properties": {
              "url": {
                "type": "string",
                "format": "uri",
                "pattern": "^https?://",
                "description": "Default service endpoint URL (must be http or https)"
              },
              "allowUserOverride": {
                "type": "boolean",
                "default": false,
                "description": "Allow users to specify a custom endpoint URL at runtime"
              }
            },
            "required": ["url"]
          },
          "credentialsSchema": {
            "type": "object",
            "description": "JSON Schema (react-jsonschema-form compatible) defining credential fields. Must be type 'object'. Supports username/password, token, and custom authentication patterns.",
            "properties": {
              "type": {
                "const": "object"
              },
              "properties": {
                "type": "object",
                "additionalProperties": {
                  "type": "object"
                }
              },
              "required": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": ["type", "properties"],
            "examples": [
              {
                "type": "object",
                "properties": {
                  "username": {
                    "type": "string",
                    "title": "Username"
                  },
                  "password": {
                    "type": "string",
                    "title": "Password",
                    "format": "password"
                  }
                },
                "required": ["username", "password"]
              },
              {
                "type": "object",
                "properties": {
                  "token": {
                    "type": "string",
                    "title": "API Token",
                    "format": "password"
                  }
                },
                "required": ["token"]
              },
              {
                "type": "object",
                "properties": {
                  "organizationId": {
                    "type": "string",
                    "title": "Organization ID"
                  },
                  "activationKey": {
                    "type": "string",
                    "title": "Activation Key",
                    "format": "password"
                  }
                },
                "required": ["organizationId", "activationKey"]
              }
            ]
          },
          "scriptPath": {
            "type": "string",
            "description": "Absolute path to the enrollment script executable (must be executable file)"
          }
        },
        "required": ["id", "name", "endpoint", "credentialsSchema", "scriptPath"]
      }
    },
    "led": {
      "type": "object",
      "description": "LED indicator configuration for visual status feedback",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable LED indicator control during onboarding"
        },
        "tool": {
          "type": "string",
          "description": "Absolute path to the LED control executable"
        },
        "states": {
          "type": "object",
          "description": "Map LED states to tool arguments. If not specified, defaults will be used.",
          "properties": {
            "ready": {
              "type": "string",
              "default": "ready",
              "description": "Argument for 'ready for onboarding' state (slow blink)"
            },
            "in-progress": {
              "type": "string",
              "default": "in-progress",
              "description": "Argument for 'wizard in progress' state (pulsing)"
            },
            "applying": {
              "type": "string",
              "default": "applying",
              "description": "Argument for 'applying configuration' state (fast blink)"
            },
            "success": {
              "type": "string",
              "default": "success",
              "description": "Argument for 'onboarding complete' state (solid on)"
            },
            "error": {
              "type": "string",
              "default": "error",
              "description": "Argument for 'error occurred' state (rapid blink)"
            },
            "off": {
              "type": "string",
              "default": "off",
              "description": "Argument for 'turn off LED' state"
            }
          }
        }
      },
      "if": {
        "properties": {
          "enabled": {
            "const": true
          }
        }
      },
      "then": {
        "required": ["tool"]
      }
    }
  },
  "required": ["version"],
  "examples": [
    {
      "version": "1.0",
      "runOnce": true,
      "keepCockpit": false,
      "hideModules": true,
      "autoReboot": false,
      "network": {
        "wifiAp": {
          "enabled": true,
          "ssidPrefix": "setup-",
          "interface": "wlan0",
          "password": "onboarding123"
        },
        "ethernet": {
          "enabled": true,
          "interface": "eth0",
          "staticIp": "192.168.100.1"
        }
      },
      "enrollmentServices": [
        {
          "id": "flightctl",
          "name": "Flight Control",
          "description": "Enroll this device into Flight Control fleet management",
          "endpoint": {
            "url": "https://flightctl.example.com",
            "allowUserOverride": true
          },
          "credentialsSchema": {
            "type": "object",
            "properties": {
              "username": {
                "type": "string",
                "title": "Username"
              },
              "password": {
                "type": "string",
                "title": "Password",
                "format": "password"
              }
            },
            "required": ["username", "password"]
          },
          "scriptPath": "/etc/cockpit/system-onboarding.d/flightctl-enroll.sh"
        }
      ],
      "led": {
        "enabled": true,
        "tool": "/usr/local/bin/led-control",
        "states": {
          "ready": "ready",
          "in-progress": "in-progress",
          "applying": "applying",
          "success": "success",
          "error": "error",
          "off": "off"
        }
      }
    }
  ]
}
