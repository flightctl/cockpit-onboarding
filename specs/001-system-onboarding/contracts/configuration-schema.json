{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cockpit-project.org/schemas/system-onboarding-config-v1.json",
  "title": "Cockpit System Onboarding Configuration",
  "description": "Configuration file schema for the Cockpit System Onboarding plugin",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0",
      "description": "Configuration schema version (must be '1.0')"
    },
    "runOnce": {
      "type": "boolean",
      "default": true,
      "description": "Disable the plugin and remove onboarding user after successful completion"
    },
    "keepCockpit": {
      "type": "boolean",
      "default": false,
      "description": "Keep Cockpit web console enabled after onboarding completion"
    },
    "hideModules": {
      "type": "boolean",
      "default": true,
      "description": "Hide other Cockpit modules during onboarding (show only System Onboarding)"
    },
    "autoReboot": {
      "type": "boolean",
      "default": false,
      "description": "Automatically reboot the system after applying configuration changes"
    },
    "brandName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Product name shown in the onboarding plugin UI. Set at build time via the BRAND_NAME environment variable."
    },
    "network": {
      "type": "object",
      "description": "Network interface configuration for initial system access",
      "properties": {
        "wifiAp": {
          "type": "object",
          "description": "WiFi access point configuration for initial wireless access",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": false,
              "description": "Enable temporary WiFi access point on first boot"
            },
            "ssidPrefix": {
              "type": "string",
              "default": "flightctl-",
              "minLength": 1,
              "maxLength": 20,
              "pattern": "^[a-zA-Z0-9_-]+$",
              "description": "SSID prefix (full SSID will be <prefix><hostname>-<random>)"
            },
            "interface": {
              "type": "string",
              "description": "WiFi interface name (e.g., 'wlan0'). If not specified, first available WiFi interface will be used."
            },
            "password": {
              "type": "string",
              "maxLength": 63,
              "default": "onboarding",
              "description": "WPA passphrase for the access point (8-63 characters). Empty string means open network (no password)."
            },
            "address": {
              "type": "string",
              "format": "ipv4",
              "default": "10.42.0.1",
              "description": "Gateway IP address for the WiFi access point network"
            },
            "subnetPrefix": {
              "type": "integer",
              "default": 24,
              "minimum": 1,
              "maximum": 30,
              "description": "CIDR subnet prefix for the WiFi AP network"
            },
            "dhcpRangeSize": {
              "type": "integer",
              "default": 40,
              "minimum": 1,
              "description": "Number of DHCP addresses in the pool (range starts at base address + 9)"
            },
            "channel": {
              "type": "integer",
              "default": 6,
              "minimum": 1,
              "maximum": 14,
              "description": "WiFi channel for the access point"
            }
          }
        },
        "ethernet": {
          "type": "object",
          "description": "Ethernet interface configuration for wired access",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true,
              "description": "Configure Ethernet interface with well-known static IP on first boot"
            },
            "interface": {
              "type": "string",
              "description": "Ethernet interface name (e.g., 'eth0', 'eno1'). If not specified, first available Ethernet interface will be used."
            },
            "staticIp": {
              "type": "string",
              "format": "ipv4",
              "default": "192.168.100.1",
              "description": "Well-known static IPv4 address for initial access"
            },
            "subnetPrefix": {
              "type": "integer",
              "default": 24,
              "minimum": 1,
              "maximum": 30,
              "description": "CIDR subnet prefix for the static IP configuration"
            },
            "dhcpRangeSize": {
              "type": "integer",
              "default": 40,
              "minimum": 1,
              "description": "Number of DHCP addresses in the pool (range starts at base IP + 9)"
            }
          }
        }
      }
    },
    "flightctl": {
      "type": "object",
      "description": "Flight Control enrollment service configuration",
      "properties": {
        "defaultEndpoint": {
          "type": "string",
          "description": "Default Flight Control server endpoint URL. Pre-populates the enrollment endpoint field in the wizard.",
          "pattern": "^(https?://.*)?$"
        }
      }
    },
    "connectivityTest": {
      "type": "object",
      "description": "Connectivity verification configuration",
      "properties": {
        "host": {
          "type": "string",
          "default": "cockpit-project.org",
          "description": "Default host for network connectivity test (DNS + ping). Overridden by the enrollment endpoint hostname when enrollment is selected."
        }
      }
    },
    "defaults": {
      "type": "object",
      "description": "Default values to pre-populate wizard form fields",
      "properties": {
        "hostname": {
          "type": "string",
          "description": "Default hostname (used when system hostname is localhost)"
        },
        "proxy": {
          "type": "object",
          "description": "Default proxy settings",
          "properties": {
            "enabled": { "type": "boolean" },
            "protocol": { "type": "string", "enum": ["http", "https", "socks5"] },
            "applyForHttps": { "type": "boolean" },
            "hostname": { "type": "string" },
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "username": { "type": "string" },
            "password": { "type": "string" },
            "noProxy": { "type": "string" }
          }
        },
        "labels": {
          "type": "object",
          "description": "Default device labels",
          "properties": {
            "deviceLabels": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "key": { "type": "string" },
                  "value": { "type": "string" }
                },
                "required": ["key", "value"]
              }
            },
            "systemInfoMappings": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "key": { "type": "string" },
                  "value": { "type": "string" }
                },
                "required": ["key", "value"]
              }
            }
          }
        },
        "alias": {
          "type": "object",
          "description": "Default alias configuration",
          "properties": {
            "mode": { "type": "string", "enum": ["hostname", "custom", "none"] },
            "customValue": { "type": "string" }
          }
        }
      }
    },
    "onboardingUser": {
      "type": "object",
      "description": "Onboarding user account configuration",
      "properties": {
        "password": {
          "type": "string",
          "default": "",
          "description": "Password for the temporary onboarding user. Empty string means passwordless login (default)."
        }
      }
    },
    "led": {
      "type": "object",
      "description": "LED indicator configuration for visual status feedback",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable LED indicator control during onboarding"
        },
        "tool": {
          "type": "string",
          "description": "Absolute path to the LED control executable"
        },
        "states": {
          "type": "object",
          "description": "Map LED states to tool arguments. If not specified, defaults will be used.",
          "properties": {
            "ready": {
              "type": "string",
              "default": "ready",
              "description": "Argument for 'ready for onboarding' state (slow blink)"
            },
            "in-progress": {
              "type": "string",
              "default": "in-progress",
              "description": "Argument for 'wizard in progress' state (pulsing)"
            },
            "applying": {
              "type": "string",
              "default": "applying",
              "description": "Argument for 'applying configuration' state (fast blink)"
            },
            "success": {
              "type": "string",
              "default": "success",
              "description": "Argument for 'onboarding complete' state (solid on)"
            },
            "error": {
              "type": "string",
              "default": "error",
              "description": "Argument for 'error occurred' state (rapid blink)"
            },
            "off": {
              "type": "string",
              "default": "off",
              "description": "Argument for 'turn off LED' state"
            }
          }
        }
      },
      "if": {
        "properties": {
          "enabled": {
            "const": true
          }
        }
      },
      "then": {
        "required": ["tool"]
      }
    }
  },
  "required": ["version"],
  "examples": [
    {
      "version": "1.0",
      "brandName": "Flight Control",
      "runOnce": true,
      "keepCockpit": false,
      "hideModules": true,
      "autoReboot": false,
      "network": {
        "wifiAp": {
          "enabled": true,
          "ssidPrefix": "flightctl-",
          "interface": "",
          "password": "",
          "address": "10.42.0.1",
          "subnetPrefix": 24,
          "dhcpRangeSize": 40,
          "channel": 6
        },
        "ethernet": {
          "enabled": true,
          "staticIp": "192.168.100.1",
          "subnetPrefix": 24,
          "dhcpRangeSize": 40
        }
      },
      "flightctl": {
        "defaultEndpoint": "https://api.flightctl.example.com"
      },
      "connectivityTest": {
        "host": "cockpit-project.org"
      },
      "onboardingUser": {
        "password": ""
      },
      "led": {
        "enabled": false,
        "tool": "/usr/local/bin/led-control",
        "states": {
          "ready": "ready",
          "in-progress": "in-progress",
          "applying": "applying",
          "success": "success",
          "error": "error",
          "off": "off"
        }
      }
    }
  ]
}
