pkgname=flightctl-onboarding
pkgver=VERSION
pkgrel=1
pkgdesc='Flightctl Onboarding Module'
arch=('x86_64')
url='https://github.com/flightctl/cockpit-onboarding'
license=(LGPL)
source=("SOURCE")
sha256sums=('SKIP')

package() {
  depends=(cockpit)
  cd $pkgname
  make DESTDIR="$pkgdir" install PREFIX=/usr
}
