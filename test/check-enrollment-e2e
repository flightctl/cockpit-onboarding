#!/usr/bin/python3 -cimport os, sys; os.execv(os.path.dirname(sys.argv[1]) + "/common/pywrap", sys.argv)

"""
End-to-end enrollment integration test

Provisions two VMs:
  - machine1: the onboarding device (WiFi image with flightctl-agent + CLI)
  - services: a Flight Control server (flightctl-services RPM)

machine1 gets a second ethernet NIC hot-plugged onto the same mcast network
already used for the base test network (see add_netiface_with_localaddr()
in wizard_navigation.py), so the wizard has an unconfigured interface to select as
"production". services is already reachable on that same network via its
base interface and just gets a second static IP added there. The wizard
configures machine1's new interface with a static IP and enrolls against
the services VM.
"""

from __future__ import annotations

import json
import os
import socket
import subprocess
import time

import testlib

from wizard_navigation import (
    IFACE_TABLE,
    add_netiface_with_localaddr,
    click_button_text,
    iface_row_selector,
    wait_for_nic,
)

AGENT_CONFIG = "/etc/flightctl/config.yaml"
LABELS_CONFIG = "/etc/flightctl/conf.d/50-cockpit-labels.yaml"
APPLY_LOG = "/var/log/flightctl-onboarding-apply.log"
TEST_DIR = os.path.dirname(__file__)


class TestEnrollmentE2EBase(testlib.MachineCase):
    """Shared setup and helpers for e2e enrollment tests.

    Provisions two VMs and hot-plugs a production NIC on machine1.
    Subclasses add their own test methods for multi-NIC or single-NIC paths.
    """

    SERVICES_IP = "10.111.118.1"
    MACHINE_IP = "10.111.118.2"
    SUBNET_MASK = "255.255.240.0"
    BASE_DOMAIN = "e2e-flightctl.test"

    provision = {
        'machine1': {
            'image': os.path.join(TEST_DIR, 'images', 'fedora-43'),
            'restrict': False,
        },
        'services': {
            'image': os.path.join(TEST_DIR, 'images', 'fedora-43-services'),
            'restrict': False,
            'memory_mb': 4096,
        },
    }

    def setUp(self):
        super().setUp()

        m = self.machine
        services = self.machines['services']

        machine1_mac = add_netiface_with_localaddr(m, self.network.interface())
        m.execute("udevadm settle")
        self.production_iface = wait_for_nic(m, machine1_mac)

        services_base_iface = services.execute(
            f"grep -l '{services.networking['mac'].lower()}' /sys/class/net/*/address"
            " | head -1 | cut -d / -f 5"
        ).strip()
        services.execute(
            f"nmcli con add type ethernet ifname {services_base_iface}"
            f" con-name production ipv4.method manual"
            f" ipv4.addresses {self.SERVICES_IP}/20"
            f" ipv4.gateway ''"
            f" connection.autoconnect yes"
        )
        services.execute("nmcli con up production")

        # dnsmasq (serving BASE_DOMAIN, baked into the image by
        # vm-flightctl-services.install) binds to the production IP, which
        # doesn't exist until the connection above comes up.
        services.execute("systemctl restart dnsmasq")

        services.execute("systemctl start flightctl.target", timeout=180)

        services.execute(
            "timeout 120 bash -c '"
            "while ! curl -sfk https://localhost/_/flightctl/readyz; do sleep 3; done"
            "'",
            timeout=130,
        )

        self.ca_cert = services.execute("cat /etc/flightctl/pki/ca.crt")
        m.write("/tmp/flightctl-ca.crt", self.ca_cert)

        self.endpoint = f"https://{self.SERVICES_IP}"

        self.config = {
            "version": "1.0",
            "runOnce": False,
            "hideModules": False,
            "flightctl": {
                "defaultEndpoint": self.endpoint,
            },
        }
        m.write(
            "/etc/cockpit/system-onboarding/config.json",
            json.dumps(self.config),
        )

    def set_react_textarea_value(self, selector, value):
        """Set a controlled React textarea's value and fire a genuine 'input' event

        Setting .value directly (as set_val/set_input_text do) updates React's
        internal value tracker along with the DOM, so a synthetic 'input' event
        dispatched afterwards looks like a no-op change and onChange never
        fires. Going through the native HTMLTextAreaElement setter first keeps
        the DOM and React's tracker out of sync, so the following event is
        seen as a real change.
        """
        self.browser.wait_visible(selector)
        self.browser.eval_js(
            "(function() {"
            f"  var el = document.querySelector({json.dumps(selector)});"
            "   var setter = Object.getOwnPropertyDescriptor("
            "       window.HTMLTextAreaElement.prototype, 'value').set;"
            f"  setter.call(el, {json.dumps(value)});"
            "   el.dispatchEvent(new Event('input', {bubbles: true}));"
            "})()"
        )

    def set_react_input_value(self, selector, value):
        """Set a controlled React input's value via the native HTMLInputElement setter"""
        self.browser.wait_visible(selector)
        self.browser.eval_js(
            "(function() {"
            f"  var el = document.querySelector({json.dumps(selector)});"
            "   var setter = Object.getOwnPropertyDescriptor("
            "       window.HTMLInputElement.prototype, 'value').set;"
            f"  setter.call(el, {json.dumps(value)});"
            "   el.dispatchEvent(new Event('input', {bubbles: true}));"
            "})()"
        )

    def navigate_to_enrollment(self):
        """Select the production interface with static IP and advance to enrollment"""
        b = self.browser

        b.wait_visible("#networkStep")
        b.wait_visible(IFACE_TABLE)
        iface_radio = f"{iface_row_selector(b, IFACE_TABLE, self.production_iface)} input[type='radio']"
        b.click(iface_radio)

        b.click("#static-ip-radio")
        b.wait_visible("#ipv4-address")
        b.set_input_text("#ipv4-address", self.MACHINE_IP)
        b.set_input_text("#subnet-mask", self.SUBNET_MASK)
        b.set_input_text("#gateway-ip", self.SERVICES_IP)

        # The services VM's OIDC issuer URL uses BASE_DOMAIN rather than an
        # IP; point DNS at the services VM (which serves that domain) so it
        # resolves during login.
        b.click("#manual-dns-ipv4-radio")
        b.wait_visible("#primary-dns-ipv4")
        b.set_input_text("#primary-dns-ipv4", self.SERVICES_IP)

        click_button_text(b, "Next")

        b.wait_visible("#networkServicesStep")
        click_button_text(b, "Next")

        b.wait_visible("#enrollmentStep")

    def fill_enrollment_form(self):
        """Navigate to enrollment step and fill in credentials + TLS config"""
        b = self.browser

        self.navigate_to_enrollment()

        b.wait_visible("#flightctl-enrollment:checked")
        b.wait_visible("#endpoint-flightctl")
        self.assertEqual(b.val("#endpoint-flightctl"), self.endpoint)

        b.click("#auth-password")
        b.wait_visible("#credential-username")
        b.wait_visible("#credential-password")
        b.set_input_text("#credential-username", "admin")
        b.set_input_text("#credential-password", "flightctl")

        b.click("#tls-custom-ca")
        self.set_react_textarea_value("#ca-cert-pem", self.ca_cert)

        b.click("#auth-ca-server")

    def query_enrollment_request_labels(self, timeout=120):
        """Wait for the agent to start, then poll the Flight Control server
        for the enrollment request labels.

        The caller is responsible for triggering cleanup (e.g. clicking Finish
        in the wizard, which runs cleanup-onboarding.sh).  The cleanup creates
        the onboarding gate file and starts flightctl-agent.  The agent reads
        /etc/flightctl/conf.d/ and sends an enrollment request whose
        spec.labels reflect the configured default-labels and
        label-from-systeminfo mappings.
        """
        m = self.machine
        services = self.machines['services']

        m.execute(
            "timeout 60 bash -c '"
            "while ! systemctl is-active --quiet flightctl-agent; do sleep 2; done"
            "'",
            timeout=65,
        )

        services.execute(
            "install -m 0600 /dev/null /tmp/creds.json && "
            "echo '{\"username\":\"admin\",\"password\":\"flightctl\"}' > /tmp/creds.json && "
            f"flightctl login https://{self.SERVICES_IP} "
            "--credentials-file /tmp/creds.json "
            "--config-dir /tmp/flightctl-cli "
            "--certificate-authority /etc/flightctl/pki/ca.crt "
            "--auth-certificate-authority /etc/flightctl/pki/ca.crt"
        )

        deadline = time.time() + timeout
        while time.time() < deadline:
            try:
                output = services.execute(
                    "flightctl get enrollmentrequests -o json "
                    "--config-dir /tmp/flightctl-cli"
                )
                data = json.loads(output)
                items = data.get("items", [])
                if items:
                    return items[0].get("spec", {}).get("labels") or {}
            except Exception:
                pass
            time.sleep(5)

        return None


class TestEnrollmentE2E(TestEnrollmentE2EBase):
    """Multi-NIC enrollment: browser stays on the base NIC, wizard configures the production NIC"""

    def testEndToEndEnrollment(self):
        """Walk through the wizard and enroll against the live server"""
        m = self.machine
        b = self.browser

        self.login_and_go(
            "/system-onboarding", user="onboarding", password="",
            superuser=False, tls=True,
        )

        self.fill_enrollment_form()

        click_button_text(b, "Next")
        b.wait_visible("#labelsStep")
        b.set_input_text("#hostname-input", "e2e-enrollment-test")

        click_button_text(b, "Next")
        b.wait_visible("#review-enrollment")

        b.wait_in_text("#review-enrollment", "Flight Control")
        b.wait_in_text("#review-enrollment", self.endpoint)

        b.click("#wizard-next-btn")
        b.wait_in_text("#progressStep", "Apply")

        with b.wait_timeout(180):
            b.wait_in_text("#apply-steps", "Enrollment credentials provisioned")

        m.execute(f"test -f {AGENT_CONFIG}")
        m.execute("systemctl is-enabled flightctl-agent")

    def testEnrollmentLoginFailure(self):
        """Verify that bad credentials produce a visible error"""
        m = self.machine
        b = self.browser

        self.login_and_go(
            "/system-onboarding", user="onboarding", password="",
            superuser=False, tls=True,
        )

        self.navigate_to_enrollment()
        b.wait_visible("#flightctl-enrollment:checked")

        b.click("#auth-password")
        b.set_input_text("#credential-username", "admin")
        b.set_input_text("#credential-password", "wrong-password")

        b.click("#tls-custom-ca")
        self.set_react_textarea_value("#ca-cert-pem", self.ca_cert)

        b.click("#auth-ca-server")

        click_button_text(b, "Next")
        b.wait_visible("#labelsStep")
        b.set_input_text("#hostname-input", "e2e-bad-creds-test")

        click_button_text(b, "Next")
        b.wait_visible("#review-enrollment")

        b.click("#wizard-next-btn")
        b.wait_in_text("#progressStep", "Apply")

        with b.wait_timeout(180):
            b.wait_in_text("#apply-steps", "flightctl login failed")

        m.execute(f"test ! -f {AGENT_CONFIG}")

    def testLabelsInEnrollmentRequest(self):
        """Verify labels configured in the wizard propagate to the enrollment request"""
        m = self.machine
        b = self.browser

        self.login_and_go(
            "/system-onboarding", user="onboarding", password="",
            superuser=False, tls=True,
        )

        self.fill_enrollment_form()

        click_button_text(b, "Next")
        b.wait_visible("#labelsStep")

        b.set_input_text("#hostname-input", "e2e-labels-test")

        b.wait_visible("#alias-enabled:checked")
        b.wait_visible("#alias-mode-hostname:checked")

        self.set_react_input_value("#device-label-key-0", "env")
        self.set_react_input_value("#device-label-value-0", "production")

        click_button_text(b, "Add another label")
        b.wait_visible("#device-label-key-1")
        self.set_react_input_value("#device-label-key-1", "region")
        self.set_react_input_value("#device-label-value-1", "us-east")

        self.set_react_input_value("#sysinfo-label-key-0", "arch")
        b.click("#sysinfo-field-0")
        b.wait_visible("#sysinfo-field-0-menu")
        b.click("#sysinfo-field-0-menu li:first-child button")

        click_button_text(b, "Next")
        b.wait_visible("#review-enrollment")

        b.click("#wizard-next-btn")
        b.wait_in_text("#progressStep", "Apply")

        with b.wait_timeout(180):
            b.wait_in_text("#apply-steps", "Enrollment credentials provisioned")
            b.wait_visible("#apply-success-alert")

        m.execute(f"test -f {AGENT_CONFIG}")
        m.execute(f"test -f {LABELS_CONFIG}")

        labels_yaml = m.execute(f"cat {LABELS_CONFIG}")
        self.assertIn("default-labels:", labels_yaml)
        self.assertIn('alias: "e2e-labels-test"', labels_yaml)
        self.assertIn('env: "production"', labels_yaml)
        self.assertIn('region: "us-east"', labels_yaml)
        self.assertIn("label-from-systeminfo:", labels_yaml)
        self.assertIn("arch: architecture", labels_yaml)

        click_button_text(b, "Finish")

        er_labels = self.query_enrollment_request_labels()
        self.assertIsNotNone(
            er_labels,
            "No enrollment request appeared on the server within the timeout",
        )

        self.assertEqual(er_labels.get("alias"), "e2e-labels-test")
        self.assertEqual(er_labels.get("env"), "production")
        self.assertEqual(er_labels.get("region"), "us-east")
        self.assertIn("arch", er_labels)
        self.assertTrue(
            len(er_labels.get("arch", "")) > 0,
            "Expected 'arch' label to have a non-empty value from system info",
        )


class TestEnrollmentE2ESingleNic(TestEnrollmentE2EBase):
    """Single-NIC enrollment via background delegation path

    Uses an SSH tunnel so the browser connects to cockpit-ws through the
    mcast NIC's IP, triggering isConnectedViaInterface() → true.  The
    wizard then delegates network activation and enrollment to
    apply-and-enroll.sh via systemd-run.
    """

    def setUp(self):
        super().setUp()
        m = self.machine

        # Assign static IP to the production mcast NIC so the SSH tunnel
        # has a stable target for cockpit-ws.
        m.execute(
            f"nmcli con add type ethernet ifname {self.production_iface}"
            f" con-name temp-e2e ipv4.method manual"
            f" ipv4.addresses {self.MACHINE_IP}/20"
            f" connection.autoconnect yes"
        )
        m.execute("nmcli con up temp-e2e")

        # Allocate a free host port for the SSH tunnel.
        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        s.bind(('127.0.0.2', 0))
        tunnel_port = s.getsockname()[1]
        s.close()

        identity = os.path.join(TEST_DIR, "..", "bots", "machine", "identity")
        self.tunnel_proc = subprocess.Popen([
            "ssh", "-N",
            "-o", "StrictHostKeyChecking=no",
            "-o", "UserKnownHostsFile=/dev/null",
            "-o", "IdentitiesOnly=yes",
            "-o", "BatchMode=yes",
            "-i", identity,
            "-p", str(m.ssh_port),
            "-L", f"127.0.0.2:{tunnel_port}:{self.MACHINE_IP}:9090",
            f"root@{m.ssh_address}",
        ], stderr=subprocess.PIPE)
        self.addCleanup(self.tunnel_proc.kill)

        time.sleep(2)
        if self.tunnel_proc.poll() is not None:
            stderr = self.tunnel_proc.stderr.read().decode() if self.tunnel_proc.stderr else ""
            raise Exception(f"SSH tunnel exited immediately: {stderr}")

        original_port = self.browser.port
        self.browser.port = tunnel_port
        self.addCleanup(lambda: setattr(self.browser, 'port', original_port))

        m.execute(
            "systemctl start flightctl-onboarding-setup.service || true",
            timeout=60,
        )

        self.config["connectivityTest"] = {
            "carrierTimeoutSeconds": 10,
            "connectivityRetries": 10,
        }
        m.write(
            "/etc/cockpit/system-onboarding/config.json",
            json.dumps(self.config),
        )

    def testEndToEndEnrollmentSingleNic(self):
        """Walk through the wizard and enroll via single-NIC background delegation"""
        m = self.machine
        b = self.browser

        m.execute(f"rm -f {APPLY_LOG}")

        self.login_and_go(
            "/system-onboarding", user="onboarding", password="",
            superuser=False, tls=True,
        )

        self.fill_enrollment_form()

        click_button_text(b, "Next")
        b.wait_visible("#labelsStep")
        b.set_input_text("#hostname-input", "e2e-singlenic-test")

        click_button_text(b, "Next")
        b.wait_visible("#reviewStep")

        b.wait_in_text(
            "#review-singlenic-warning",
            "Connection will be interrupted",
        )

        b.click("#wizard-next-btn")
        b.wait_in_text("#progressStep", "Apply")

        with b.wait_timeout(120):
            b.wait_in_text(
                "#apply-singlenic-alert",
                "Onboarding continues in the background",
            )

        deadline = time.time() + 180
        completed = False
        while time.time() < deadline:
            try:
                log = m.execute(f"cat {APPLY_LOG} 2>/dev/null || true")
                if "Onboarding completed successfully" in log:
                    completed = True
                    break
            except Exception:
                pass
            time.sleep(5)

        self.assertTrue(
            completed,
            f"Background enrollment did not complete within timeout. Log:\n"
            f"{m.execute(f'cat {APPLY_LOG} 2>/dev/null || echo no-log')}",
        )

        m.execute(f"test -f {AGENT_CONFIG}")
        m.execute("systemctl is-enabled flightctl-agent")

    def testEnrollmentSingleNicLoginFailure(self):
        """Verify bad credentials cause rollback in single-NIC delegation"""
        m = self.machine
        b = self.browser

        m.execute(f"rm -f {APPLY_LOG}")
        original_hostname = m.execute("hostnamectl --static").strip()

        self.login_and_go(
            "/system-onboarding", user="onboarding", password="",
            superuser=False, tls=True,
        )

        self.navigate_to_enrollment()
        b.wait_visible("#flightctl-enrollment:checked")

        b.click("#auth-password")
        b.set_input_text("#credential-username", "admin")
        b.set_input_text("#credential-password", "wrong-password")

        b.click("#tls-custom-ca")
        self.set_react_textarea_value("#ca-cert-pem", self.ca_cert)

        click_button_text(b, "Next")
        b.wait_visible("#labelsStep")
        b.set_input_text("#hostname-input", "e2e-singlenic-fail")

        click_button_text(b, "Next")
        b.wait_visible("#reviewStep")

        b.wait_in_text(
            "#review-singlenic-warning",
            "Connection will be interrupted",
        )

        b.click("#wizard-next-btn")
        b.wait_in_text("#progressStep", "Apply")

        with b.wait_timeout(120):
            b.wait_in_text(
                "#apply-singlenic-alert",
                "Onboarding continues in the background",
            )

        deadline = time.time() + 180
        rollback_confirmed = False
        while time.time() < deadline:
            try:
                log = m.execute(f"cat {APPLY_LOG} 2>/dev/null || true")
                if "Rollback complete" in log:
                    rollback_confirmed = True
                    break
            except Exception:
                pass
            time.sleep(5)

        self.assertTrue(
            rollback_confirmed,
            f"Rollback did not complete within timeout. Log:\n"
            f"{m.execute(f'cat {APPLY_LOG} 2>/dev/null || echo no-log')}",
        )

        log = m.execute(f"cat {APPLY_LOG}")
        self.assertIn("Enrollment script failed", log)

        m.execute(f"test ! -f {AGENT_CONFIG}")

        nm_connections = m.execute("nmcli -t -f NAME connection show")
        self.assertNotIn(
            f"flightctl-onboarding-{self.production_iface}",
            nm_connections,
        )

        restored_hostname = m.execute("hostnamectl --static").strip()
        self.assertEqual(restored_hostname, original_hostname)


