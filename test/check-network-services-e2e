#!/usr/bin/python3 -cimport os, sys; os.execv(os.path.dirname(sys.argv[1]) + "/common/pywrap", sys.argv)

"""
End-to-end tests for NTP and HTTP proxy network services

Provisions VMs:
  - machine1: the onboarding device (WiFi image with flightctl-agent + CLI)
  - network_services: Squid HTTP proxy + chrony NTP server
  - services (3-VM tests only): Flight Control server for enrollment

The 2-VM tests (TestNtpE2E, TestProxyE2E) verify that NTP and proxy
configuration is correctly applied to system files. The 3-VM test
(TestEnrollmentThroughProxyE2E) verifies that enrollment traffic flows
through a real Squid proxy.
"""

from __future__ import annotations

import json
import os
import time

import testlib

from wizard_navigation import (
    IFACE_TABLE,
    add_netiface_with_localaddr,
    click_button_text,
    iface_row_selector,
    wait_for_nic,
)

AGENT_CONFIG = "/etc/flightctl/config.yaml"
APPLY_LOG = "/var/log/flightctl-onboarding-apply.log"
TEST_DIR = os.path.dirname(__file__)

SERVICES_IP = "10.111.118.1"
MACHINE_IP = "10.111.118.2"
NETSERVICES_IP = "10.111.118.3"
SUBNET_MASK = "255.255.240.0"
BASE_DOMAIN = "e2e-flightctl.test"
SQUID_PORT = "3128"


NTP_BACKEND = "chronyd"


def assert_ntp_manual_applied(test, machine, server):
    """Verify the NTP config file contains the expected server"""
    if NTP_BACKEND == "timesyncd":
        conf = machine.execute(
            "cat /etc/systemd/timesyncd.conf.d/50-cockpit.conf"
        )
        test.assertIn(server, conf)
    else:
        sources = machine.execute(
            "cat /etc/chrony/sources.d/cockpit.sources"
        )
        test.assertIn(f"server {server}", sources)


def assert_ntp_auto_applied(test, machine):
    """Verify auto-mode NTP removed any custom config drop-in"""
    if NTP_BACKEND == "timesyncd":
        rc = machine.execute(
            "test -f /etc/systemd/timesyncd.conf.d/50-cockpit.conf"
            " && echo exists || echo absent"
        ).strip()
        test.assertEqual(rc, "absent")
    else:
        rc = machine.execute(
            "test -f /etc/chrony/sources.d/cockpit.sources"
            " && echo exists || echo absent"
        ).strip()
        test.assertEqual(rc, "absent")


class TestNetworkServicesE2EBase(testlib.MachineCase):
    """Shared setup for NTP/proxy e2e tests (2 VMs: device + network_services).

    Hot-plugs a production NIC on machine1 and brings up chrony + squid
    on the network_services VM so both services are reachable.
    """

    provision = {
        'machine1': {
            'image': os.path.join(TEST_DIR, 'images', 'fedora-43'),
            'restrict': False,
        },
        'network_services': {
            'image': os.path.join(TEST_DIR, 'images', 'fedora-43-network-services'),
            'restrict': False,
        },
    }

    def setUp(self):
        super().setUp()
        m = self.machine
        ns = self.machines['network_services']

        machine1_mac = add_netiface_with_localaddr(m, self.network.interface())
        m.execute("udevadm settle")
        self.production_iface = wait_for_nic(m, machine1_mac)

        ns_base_iface = ns.execute(
            f"grep -l '{ns.networking['mac'].lower()}' /sys/class/net/*/address"
            " | head -1 | cut -d / -f 5"
        ).strip()
        ns.execute(
            f"nmcli con add type ethernet ifname {ns_base_iface}"
            f" con-name production ipv4.method manual"
            f" ipv4.addresses {NETSERVICES_IP}/20"
            f" ipv4.gateway ''"
            f" connection.autoconnect yes"
        )
        ns.execute("nmcli con up production")

        ns.execute("systemctl start chronyd")
        ns.execute("systemctl start squid")

        m.execute("systemctl start chronyd")
        m.execute(
            "systemctl start flightctl-onboarding-setup.service || true",
            timeout=60,
        )

        self.config = {
            "version": "1.0",
            "runOnce": False,
            "hideModules": False,
            "connectivityTest": {
                "host": NETSERVICES_IP,
            },
        }
        m.write(
            "/etc/cockpit/system-onboarding/config.json",
            json.dumps(self.config),
        )

    def select_production_nic_with_static_ip(self):
        """Select the production NIC and configure a static IP in the test subnet"""
        b = self.browser

        b.wait_visible("#networkStep")
        b.wait_visible(IFACE_TABLE)
        iface_radio = (
            f"{iface_row_selector(b, IFACE_TABLE, self.production_iface)}"
            f" input[type='radio']"
        )
        b.click(iface_radio)

        b.click("#static-ip-radio")
        b.wait_visible("#ipv4-address")
        b.set_input_text("#ipv4-address", MACHINE_IP)
        b.set_input_text("#subnet-mask", SUBNET_MASK)
        b.set_input_text("#gateway-ip", NETSERVICES_IP)

        click_button_text(b, "Next")
        b.wait_visible("#networkServicesStep")

    def configure_ntp_manual(self, server):
        """Toggle NTP to manual and enter a server address"""
        b = self.browser

        b.click("label[for='ntp-servers']")
        b.wait_visible("#ntp-servers:checked")
        b.wait_visible("#ntp-server-input")
        b.set_input_text("#ntp-server-input", server)

    def configure_proxy(self, hostname, port, username=None, password=None):
        """Enable proxy and fill in connection details"""
        b = self.browser

        b.click("label[for='proxy-enabled']")
        b.wait_visible("#proxy-enabled:checked")
        b.wait_visible("#proxy-hostname-input")
        b.set_input_text("#proxy-hostname-input", hostname)
        b.set_input_text("#proxy-port-input", port)
        if username:
            b.set_input_text("#proxy-username-input", username)
        if password:
            b.set_input_text("#proxy-password-input", password)

    def skip_enrollment_and_apply(self, hostname):
        """Disable enrollment, set hostname, review, and start apply"""
        b = self.browser

        b.wait_visible("#enrollmentStep")
        if b.is_present("#flightctl-enrollment:checked"):
            b.click("label[for='flightctl-enrollment']")
            b.wait_not_present("#flightctl-enrollment:checked")
        click_button_text(b, "Next")

        b.wait_visible("#labelsStep")
        b.set_input_text("#hostname-input", hostname)
        click_button_text(b, "Next")

        b.wait_visible("#reviewStep")
        b.click("#wizard-next-btn")
        b.wait_in_text("#progressStep", "Apply")


class TestNtpE2E(TestNetworkServicesE2EBase):
    """Verify NTP configuration is applied to the system via configure-ntp.sh"""

    def testNtpManualServersApplied(self):
        """Configure a manual NTP server and verify the client contacts it"""
        m = self.machine
        ns = self.machines['network_services']
        b = self.browser

        self.login_and_go(
            "/system-onboarding", user="onboarding", password="",
            superuser=False, tls=True,
        )

        self.select_production_nic_with_static_ip()
        self.configure_ntp_manual(NETSERVICES_IP)
        click_button_text(b, "Next")

        self.skip_enrollment_and_apply("ntp-manual-test")

        with b.wait_timeout(120):
            b.wait_in_text(
                "#apply-success-alert",
                "Configuration completed successfully",
            )

        assert_ntp_manual_applied(self, m, NETSERVICES_IP)

        ntp_status = m.execute(
            "timedatectl show --property=NTP --value"
        ).strip()
        self.assertEqual(ntp_status, "yes")

        deadline = time.time() + 60
        while time.time() < deadline:
            clients = ns.execute("chronyc clients")
            if MACHINE_IP in clients:
                break
            time.sleep(2)
        clients = ns.execute("chronyc clients")
        self.assertIn(
            MACHINE_IP, clients,
            "NTP server should see machine1 as a client",
        )

    def testNtpAutoConfigApplied(self):
        """Leave NTP in auto mode and verify no custom sources are written"""
        m = self.machine
        b = self.browser

        self.login_and_go(
            "/system-onboarding", user="onboarding", password="",
            superuser=False, tls=True,
        )

        self.select_production_nic_with_static_ip()
        click_button_text(b, "Next")

        self.skip_enrollment_and_apply("ntp-auto-test")

        with b.wait_timeout(120):
            b.wait_in_text(
                "#apply-success-alert",
                "Configuration completed successfully",
            )

        assert_ntp_auto_applied(self, m)

        ntp_status = m.execute(
            "timedatectl show --property=NTP --value"
        ).strip()
        self.assertEqual(ntp_status, "yes")


class TestProxyE2E(TestNetworkServicesE2EBase):
    """Verify proxy configuration is applied to /etc/environment and systemd"""

    def testProxyConfigApplied(self):
        """Configure proxy without auth and verify system config files"""
        m = self.machine
        ns = self.machines['network_services']
        b = self.browser

        ns.execute("truncate -s0 /var/log/squid/access.log")

        self.login_and_go(
            "/system-onboarding", user="onboarding", password="",
            superuser=False, tls=True,
        )

        self.select_production_nic_with_static_ip()
        self.configure_proxy(NETSERVICES_IP, SQUID_PORT)
        click_button_text(b, "Next")

        self.skip_enrollment_and_apply("proxy-test")

        with b.wait_timeout(120):
            b.wait_in_text(
                "#apply-success-alert",
                "Configuration completed successfully",
            )

        expected_url = f"http://{NETSERVICES_IP}:{SQUID_PORT}"

        env = m.execute("cat /etc/environment")
        self.assertIn(f'HTTP_PROXY="{expected_url}"', env)
        self.assertIn(f'HTTPS_PROXY="{expected_url}"', env)
        self.assertIn('NO_PROXY="localhost,127.0.0.1,::1"', env)

        dropin = m.execute(
            "cat /etc/systemd/system.conf.d/"
            "50-flightctl-onboarding-proxy.conf"
        )
        self.assertIn(f'"HTTP_PROXY={expected_url}"', dropin)
        self.assertIn(f'"HTTPS_PROXY={expected_url}"', dropin)

        ns.execute("truncate -s0 /var/log/squid/access.log")
        m.execute(
            f"curl --max-time 10"
            f" -x {expected_url} http://test.invalid/ || true"
        )
        access_log = ns.execute("cat /var/log/squid/access.log")
        self.assertIn(
            "test.invalid",
            access_log,
            "Squid access log should contain the proxied request for test.invalid",
        )

    def testProxyWithAuthConfigApplied(self):
        """Configure proxy with credentials and verify separation of secrets"""
        m = self.machine
        ns = self.machines['network_services']
        b = self.browser

        self.login_and_go(
            "/system-onboarding", user="onboarding", password="",
            superuser=False, tls=True,
        )

        self.select_production_nic_with_static_ip()
        self.configure_proxy(
            NETSERVICES_IP, SQUID_PORT, "proxyuser", "proxypass"
        )
        click_button_text(b, "Next")

        self.skip_enrollment_and_apply("proxy-auth-test")

        with b.wait_timeout(120):
            b.wait_in_text(
                "#apply-success-alert",
                "Configuration completed successfully",
            )

        dropin = m.execute(
            "cat /etc/systemd/system.conf.d/"
            "50-flightctl-onboarding-proxy.conf"
        )
        self.assertIn(
            f"proxyuser:proxypass@{NETSERVICES_IP}:{SQUID_PORT}",
            dropin,
        )

        env = m.execute("cat /etc/environment")
        self.assertNotIn("proxyuser", env)
        self.assertNotIn("proxypass", env)
        self.assertIn(
            f'HTTP_PROXY="http://{NETSERVICES_IP}:{SQUID_PORT}"', env
        )

        perms = m.execute(
            "stat -c %a /etc/systemd/system.conf.d/"
            "50-flightctl-onboarding-proxy.conf"
        ).strip()
        self.assertEqual(perms, "600")

        env_perms = m.execute("stat -c %a /etc/environment").strip()
        self.assertEqual(env_perms, "644")

        ns.execute(
            "cp /etc/squid/squid-auth-required.conf /etc/squid/squid.conf"
        )
        ns.execute("squid -k reconfigure")
        m.execute("systemctl daemon-reexec")
        time.sleep(2)

        proxy_url = f"http://{NETSERVICES_IP}:{SQUID_PORT}"
        rc_noauth = m.execute(
            f"curl -o /dev/null -s -w '%{{http_code}}' --max-time 10"
            f" -x {proxy_url} http://test.invalid/ || true"
        ).strip()
        self.assertEqual(
            rc_noauth, "407",
            "Bare curl without systemd env should get 407 Proxy Auth Required",
        )

        rc_systemd = m.execute(
            "systemd-run --pipe --wait --quiet"
            " curl -o /dev/null -s -w '%{http_code}' --max-time 10"
            f" http://test.invalid/ 2>/dev/null || true"
        ).strip()
        self.assertNotEqual(
            rc_systemd, "407",
            "Process inheriting DefaultEnvironment should authenticate via proxy",
        )


class TestEnrollmentThroughProxyE2E(testlib.MachineCase):
    """Enroll against Flight Control through a real Squid proxy (3 VMs)"""

    provision = {
        'machine1': {
            'image': os.path.join(TEST_DIR, 'images', 'fedora-43'),
            'restrict': False,
        },
        'network_services': {
            'image': os.path.join(TEST_DIR, 'images', 'fedora-43-network-services'),
            'restrict': False,
        },
        'services': {
            'image': os.path.join(TEST_DIR, 'images', 'fedora-43-services'),
            'restrict': False,
            'memory_mb': 4096,
        },
    }

    def setUp(self):
        super().setUp()
        m = self.machine
        ns = self.machines['network_services']
        services = self.machines['services']

        machine1_mac = add_netiface_with_localaddr(m, self.network.interface())
        m.execute("udevadm settle")
        self.production_iface = wait_for_nic(m, machine1_mac)

        # ── network_services VM (Squid + chrony) ──────────────────────
        ns_base_iface = ns.execute(
            f"grep -l '{ns.networking['mac'].lower()}' /sys/class/net/*/address"
            " | head -1 | cut -d / -f 5"
        ).strip()
        ns.execute(
            f"nmcli con add type ethernet ifname {ns_base_iface}"
            f" con-name production ipv4.method manual"
            f" ipv4.addresses {NETSERVICES_IP}/20"
            f" ipv4.gateway ''"
            f" connection.autoconnect yes"
        )
        ns.execute("nmcli con up production")
        ns.execute("systemctl start chronyd")
        ns.execute("systemctl start squid")
        ns.execute("truncate -s0 /var/log/squid/access.log")

        # ── services VM (Flight Control) ──────────────────────────────
        services_base_iface = services.execute(
            f"grep -l '{services.networking['mac'].lower()}'"
            " /sys/class/net/*/address"
            " | head -1 | cut -d / -f 5"
        ).strip()
        services.execute(
            f"nmcli con add type ethernet ifname {services_base_iface}"
            f" con-name production ipv4.method manual"
            f" ipv4.addresses {SERVICES_IP}/20"
            f" ipv4.gateway ''"
            f" connection.autoconnect yes"
        )
        services.execute("nmcli con up production")
        services.execute("systemctl restart dnsmasq")
        services.execute("systemctl start flightctl.target", timeout=180)
        services.execute(
            "timeout 120 bash -c '"
            "while ! curl -sfk https://localhost/_/flightctl/readyz;"
            " do sleep 3; done"
            "'",
            timeout=130,
        )

        self.ca_cert = services.execute("cat /etc/flightctl/pki/ca.crt")
        m.write("/tmp/flightctl-ca.crt", self.ca_cert)
        self.endpoint = f"https://{SERVICES_IP}"

        # ── machine1 ─────────────────────────────────────────────────
        m.execute(
            "systemctl start flightctl-onboarding-setup.service || true",
            timeout=60,
        )

        self.config = {
            "version": "1.0",
            "runOnce": False,
            "hideModules": False,
            "flightctl": {
                "defaultEndpoint": self.endpoint,
            },
        }
        m.write(
            "/etc/cockpit/system-onboarding/config.json",
            json.dumps(self.config),
        )

    def set_react_textarea_value(self, selector, value):
        """Set a controlled React textarea via native setter to trigger onChange"""
        self.browser.wait_visible(selector)
        self.browser.eval_js(
            "(function() {"
            f"  var el = document.querySelector({json.dumps(selector)});"
            "   var setter = Object.getOwnPropertyDescriptor("
            "       window.HTMLTextAreaElement.prototype, 'value').set;"
            f"  setter.call(el, {json.dumps(value)});"
            "   el.dispatchEvent(new Event('input', {bubbles: true}));"
            "})()"
        )

    def testEnrollmentThroughProxy(self):
        """Walk the full wizard with NTP + proxy and enroll through squid"""
        m = self.machine
        ns = self.machines['network_services']
        b = self.browser

        self.login_and_go(
            "/system-onboarding", user="onboarding", password="",
            superuser=False, tls=True,
        )

        # ── Network step ──────────────────────────────────────────────
        b.wait_visible("#networkStep")
        b.wait_visible(IFACE_TABLE)
        iface_radio = (
            f"{iface_row_selector(b, IFACE_TABLE, self.production_iface)}"
            f" input[type='radio']"
        )
        b.click(iface_radio)

        b.click("#static-ip-radio")
        b.wait_visible("#ipv4-address")
        b.set_input_text("#ipv4-address", MACHINE_IP)
        b.set_input_text("#subnet-mask", SUBNET_MASK)
        b.set_input_text("#gateway-ip", SERVICES_IP)

        b.click("#manual-dns-ipv4-radio")
        b.wait_visible("#primary-dns-ipv4")
        b.set_input_text("#primary-dns-ipv4", SERVICES_IP)

        click_button_text(b, "Next")

        # ── Network Services step ─────────────────────────────────────
        b.wait_visible("#networkServicesStep")

        b.click("label[for='ntp-servers']")
        b.wait_visible("#ntp-servers:checked")
        b.wait_visible("#ntp-server-input")
        b.set_input_text("#ntp-server-input", NETSERVICES_IP)

        b.click("label[for='proxy-enabled']")
        b.wait_visible("#proxy-enabled:checked")
        b.set_input_text("#proxy-hostname-input", NETSERVICES_IP)
        b.set_input_text("#proxy-port-input", SQUID_PORT)

        click_button_text(b, "Next")

        # ── Enrollment step ───────────────────────────────────────────
        b.wait_visible("#enrollmentStep")
        b.wait_visible("#flightctl-enrollment:checked")
        b.wait_visible("#endpoint-flightctl")
        self.assertEqual(b.val("#endpoint-flightctl"), self.endpoint)

        b.click("#auth-password")
        b.set_input_text("#credential-username", "admin")
        b.set_input_text("#credential-password", "flightctl")

        b.click("#tls-custom-ca")
        self.set_react_textarea_value("#ca-cert-pem", self.ca_cert)

        click_button_text(b, "Next")

        # ── Labels step ───────────────────────────────────────────────
        b.wait_visible("#labelsStep")
        b.set_input_text("#hostname-input", "e2e-proxy-enroll-test")
        click_button_text(b, "Next")

        # ── Review + Apply ────────────────────────────────────────────
        b.wait_visible("#reviewStep")
        b.click("#wizard-next-btn")
        b.wait_in_text("#progressStep", "Apply")

        with b.wait_timeout(180):
            b.wait_in_text(
                "#apply-success-alert",
                "Configuration completed successfully",
            )

        m.execute(f"test -f {AGENT_CONFIG}")
        m.execute("systemctl is-enabled flightctl-agent")

        env = m.execute("cat /etc/environment")
        self.assertIn(f"http://{NETSERVICES_IP}:{SQUID_PORT}", env)

        enrollment_log = ns.execute("cat /var/log/squid/access.log")
        self.assertIn(
            f"CONNECT {SERVICES_IP}:443",
            enrollment_log,
            "Squid should show CONNECT to flightctl during enrollment credential generation",
        )

        ns.execute("truncate -s0 /var/log/squid/access.log")
        click_button_text(b, "Finish")

        m.execute(
            "timeout 60 bash -c '"
            "while ! systemctl is-active --quiet flightctl-agent;"
            " do sleep 3; done"
            "'",
            timeout=70,
        )

        deadline = time.time() + 60
        while time.time() < deadline:
            agent_log = ns.execute("cat /var/log/squid/access.log")
            if f"CONNECT {SERVICES_IP}:443" in agent_log:
                break
            time.sleep(3)
        agent_log = ns.execute("cat /var/log/squid/access.log")
        self.assertIn(
            f"CONNECT {SERVICES_IP}:443",
            agent_log,
            "Squid should show CONNECT from flightctl-agent after enrollment",
        )

        assert_ntp_manual_applied(self, m, NETSERVICES_IP)


